<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txt_hesapsahibi"
        android:layout_width="242dp"
        android:layout_height="49dp"
        android:layout_marginStart="92dp"
        android:layout_marginTop="200dp"
        android:hint="Hesap Sahibi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_hesaptürü"
        android:layout_width="242dp"
        android:layout_height="49dp"
        android:layout_marginStart="92dp"
        android:layout_marginTop="72dp"
        android:hint="Hesap Bakiyesi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_hesapbakiyesi" />

    <TextView
        android:id="@+id/txt_hesapbakiyesi"
        android:layout_width="242dp"
        android:layout_height="49dp"
        android:layout_marginStart="92dp"
        android:layout_marginTop="64dp"
        android:hint="Hesap Türü"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_hesapsahibi" />
</androidx.constraintlayout.widget.ConstraintLayout>